# ============================================================================
# services.conf - Service Manager Configuration
# ============================================================================
# Copy this file to services.conf and fill in your values.
# This file is gitignored — do not commit it to the repository.
# Back up this file separately (password manager, encrypted note, etc).
# ============================================================================

# ---------- Service Count ----------
# Total number of programs to manage. Each uses SERVICE_N_* variables.
SERVICE_COUNT="2"

# ---------- Service 1 ----------
SERVICE_1_NAME="myapp1"
SERVICE_1_PATH="/usr/bin/myapp1"
SERVICE_1_ARGS=""
SERVICE_1_USER="pi"

# Optional: environment variables for starting the program, semicolon-separated.
# Example for GUI apps: "DISPLAY=:0"
SERVICE_1_ENV="DISPLAY=:0"

# Optional: pattern for pgrep to detect if the program is running.
# Defaults to the basename of PATH. Override if needed (e.g., if the process
# name differs from the binary name).
SERVICE_1_PGREP=""

# Optional: command to run before sending SIGTERM on scheduled shutdown.
# Example: "/usr/bin/myapp1 --flush"
SERVICE_1_PRE_SHUTDOWN=""

# Optional: path to a log file for logrotate (leave empty if not needed)
SERVICE_1_LOG_FILE=""

# Optional: memory cap. Program is restarted if RSS exceeds this.
# Examples: "256M", "512M", "1G"
SERVICE_1_MEMORY_MAX=""

# Optional: custom health check command. Exit 0 = healthy, non-zero = restart.
# Examples:
#   "curl -sf http://localhost:8080/health"
#   "test -f /tmp/myapp1.heartbeat"
SERVICE_1_HEALTH_CMD=""

# Optional: hours to offset this program's restart from the base cycle.
# Staggers restarts so they don't all happen at the same time.
SERVICE_1_STAGGER_HOURS="0"

# Optional: set to "true" to only monitor resources without starting/stopping.
# The program will be tracked for memory and CPU but never started or restarted.
SERVICE_1_WATCH_ONLY="false"

# ---------- Service 2 ----------
SERVICE_2_NAME="myapp2"
SERVICE_2_PATH="/usr/bin/myapp2"
SERVICE_2_ARGS=""
SERVICE_2_USER="pi"
SERVICE_2_ENV="DISPLAY=:0"
SERVICE_2_PGREP=""
SERVICE_2_PRE_SHUTDOWN=""
SERVICE_2_LOG_FILE=""
SERVICE_2_MEMORY_MAX=""
SERVICE_2_HEALTH_CMD=""
SERVICE_2_STAGGER_HOURS="24"
SERVICE_2_WATCH_ONLY="false"

# ---------- Timing ----------
# Base restart interval in days. Each program may add STAGGER_HOURS on top.
RESTART_INTERVAL_DAYS="3"

# Delay in seconds between stopping and restarting during a scheduled restart.
# 300 = 5 minutes. Only applies to scheduled restarts, not crash recovery.
RESTART_DELAY_SECS="300"

# How often the health check runs. Uses systemd time syntax.
# Examples: "2h", "30min", "1h30min"
HEALTH_CHECK_INTERVAL="2h"

# ---------- CPU Monitoring ----------
# CPU threshold percentage. Programs exceeding this are flagged in the log
# and memory CSV. Informational only — does not trigger a restart.
CPU_THRESHOLD="90"

# ---------- Notifications ----------
# Webhook URL for failure notifications (Slack, Discord, ntfy, etc).
# Leave empty to log failures to systemd journal only.
NOTIFY_WEBHOOK_URL=""

# Email address for failure notifications. Requires msmtp or sendmail.
NOTIFY_EMAIL=""
NOTIFY_EMAIL_FROM="svc-manager@raspberrypi"

# ---------- Config Backup ----------
# Directory to copy services.conf on each install/update. Leave empty to skip.
CONFIG_BACKUP_DIR=""

# ---------- Dashboard ----------
# Port for the JSON status endpoint. Set to 0 to disable.
# Endpoints:
#   GET /status  — current state, PID, memory, CPU, restart countdown
#   GET /memory  — recent entries from the memory trend CSV
DASHBOARD_PORT="0"
